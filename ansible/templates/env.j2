# Database Configuration
DATABASE_URL=postgresql://sports_user:{{ vault_postgres_password }}@postgres:5432/sports_data
POSTGRES_PASSWORD={{ vault_postgres_password }}

# API Configuration
API_PORT={{ api_port }}
CRICAPI_KEY={{ vault_cricapi_key | default('') }}
CRICAPI_MAX_REQUESTS_PER_DAY={{ cricapi_max_requests_per_day | default(2000) }}
CRICAPI_MAX_REQUESTS_PER_HOUR={{ cricapi_max_requests_per_hour | default(300) }}
CRICAPI_USAGE_RESERVE={{ cricapi_usage_reserve | default(200) }}

# TheSportsDB (lifetime license, replacing several upstreams)
THESPORTSDB_KEY={{ vault_thesportsdb_key | default('') }}
THESPORTSDB_MAX_REQUESTS_PER_HOUR={{ thesportsdb_max_requests_per_hour | default(600) }}
NBA_PROVIDER={{ nba_provider | default('thesportsdb') }}
CRICKET_PROVIDER={{ cricket_provider | default('thesportsdb') }}
CRICKET_LIVE_ENRICHMENT={{ cricket_live_enrichment | default('cricapi') }}
# CricAPI key is shared with another project and capped at 2000 hits/day. With
# the multi-timezone frontend loop, force-refreshing live matches blew quota in
# 3 hours. Disabled in both envs; live cricket scores intra-day are sacrificed
# until we add per-(league,context) coalescing across timezones.
CRICAPI_LIVE_REFRESH=false
CRICAPI_CACHE_TTL={{ 3600 if deployment_env == 'dev' else 900 }}
CRICAPI_SEASON_CACHE_TTL={{ 3600 if deployment_env == 'dev' else 300 }}

# Logging
LOG_LEVEL=INFO

# Polling Configuration
DEFAULT_POLL_INTERVAL=120
CLOSE_GAME_POLL_INTERVAL=60
SCHEDULED_GAME_POLL_INTERVAL=300

# Close game thresholds by league
NBA_CLOSE_GAME_THRESHOLD=10
NFL_CLOSE_GAME_THRESHOLD=10
NHL_CLOSE_GAME_THRESHOLD=2
MLB_CLOSE_GAME_THRESHOLD=3
WNBA_CLOSE_GAME_THRESHOLD=10
MLS_CLOSE_GAME_THRESHOLD=2
IPL_CLOSE_GAME_THRESHOLD=20
MLC_CLOSE_GAME_THRESHOLD=20

# Schedule update times (24-hour format)
SCHEDULE_UPDATE_TIMES=06:00,18:00

# Live polling hours
LIVE_POLLING_HOURS=10:00-23:30

# API Rate Limiting
NBA_MAX_REQUESTS_PER_MINUTE=60
MLB_MAX_REQUESTS_PER_MINUTE=30
NHL_MAX_REQUESTS_PER_MINUTE=60
NFL_MAX_REQUESTS_PER_MINUTE=30
WNBA_MAX_REQUESTS_PER_MINUTE=60
MLS_MAX_REQUESTS_PER_MINUTE=60
IPL_MAX_REQUESTS_PER_MINUTE=60
MLC_MAX_REQUESTS_PER_MINUTE=60

# Paid API Budget Limits
NFL_MAX_REQUESTS_PER_DAY=1000
NFL_MAX_REQUESTS_PER_HOUR=150
NFL_MAX_REQUESTS_PER_MONTH=10000
WNBA_MAX_REQUESTS_PER_MONTH=14000
WNBA_MAX_REQUESTS_PER_DAY=460
WNBA_MAX_REQUESTS_PER_HOUR=80
WNBA_MAX_REQUESTS_PER_SECOND=10

# Deployment Information
DEPLOYMENT_ENV={{ deployment_env }}
DEPLOYMENT_TIMESTAMP={{ ansible_date_time.epoch }}
GITHUB_SHA={{ github_sha }}

# WNBA API Key (wnba-api.p.rapidapi.com)
WNBA_API_KEY={{ vault_wnba_api_key }}
