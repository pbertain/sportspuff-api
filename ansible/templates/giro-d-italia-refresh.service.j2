[Unit]
Description=Giro d'Italia Bundle Refresher ({{ deployment_env }})
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ansible
WorkingDirectory={{ deployment_dir }}/giro-scraper
ExecStart={{ deployment_dir }}/giro-scraper/.venv/bin/python {{ deployment_dir }}/giro-scraper/refresh_if_due.py --outdir {{ deployment_dir }}/giro-scraper
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
